@page "/settings"
@rendermode InteractiveServer
@inject IClinicSettingsService SettingsService
@inject NotificationService NotificationService
@inject ILogger<ClinicSettingsPage> Logger
@using ClinicManagementSystem.Models.Entities
@using ClinicManagementSystem.Services.Interfaces

<PageTitle>Clinic Settings</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.H4">Clinic Settings</RadzenText>

    <RadzenCard>
        <RadzenTemplateForm TItem="ClinicSettings" Data="@_settings" Submit="@Save">
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="6"><RadzenTextBox @bind-Value="_settings.ClinicName" Placeholder="Clinic name" Style="width:100%" /></RadzenColumn>
                <RadzenColumn Size="6"><RadzenTextBox @bind-Value="_settings.Email" Placeholder="Email" Style="width:100%" /></RadzenColumn>
                <RadzenColumn Size="6"><RadzenTextBox @bind-Value="_settings.PhoneNumber" Placeholder="Phone" Style="width:100%" /></RadzenColumn>
                <RadzenColumn Size="6"><RadzenTextBox @bind-Value="_settings.Address" Placeholder="Address" Style="width:100%" /></RadzenColumn>
                <RadzenColumn Size="4"><RadzenDatePicker @bind-Value="_opening" ShowTime="true" TimeOnly="true" DateFormat="HH:mm" /></RadzenColumn>
                <RadzenColumn Size="4"><RadzenDatePicker @bind-Value="_closing" ShowTime="true" TimeOnly="true" DateFormat="HH:mm" /></RadzenColumn>
                <RadzenColumn Size="4"><RadzenNumeric @bind-Value="_settings.DefaultAppointmentDurationMinutes" Min="5" Placeholder="Default duration (minutes)" /></RadzenColumn>
                <RadzenColumn Size="12"><RadzenButton ButtonType="ButtonType.Submit" Text="Save" Icon="save" ButtonStyle="ButtonStyle.Primary" /></RadzenColumn>
            </RadzenRow>
        </RadzenTemplateForm>
    </RadzenCard>
</RadzenStack>

<RadzenNotification />

@code {
    private ClinicSettings _settings = new();
    private DateTime _opening = DateTime.Today.AddHours(8);
    private DateTime _closing = DateTime.Today.AddHours(18);

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Loading clinic settings page");
        _settings = await SettingsService.GetCurrentAsync() ?? new ClinicSettings();
        _opening = DateTime.Today.Add(_settings.OpeningTime);
        _closing = DateTime.Today.Add(_settings.ClosingTime);
    }

    private async Task Save()
    {
        _settings.OpeningTime = _opening.TimeOfDay;
        _settings.ClosingTime = _closing.TimeOfDay;
        _settings = await SettingsService.UpsertAsync(_settings);
        NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Settings saved" });
    }
}
