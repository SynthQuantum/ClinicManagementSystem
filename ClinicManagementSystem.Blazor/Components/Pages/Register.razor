@page "/register"
@page "/Account/Register"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using ClinicManagementSystem.Models.Entities
@using ClinicManagementSystem.Models.Enums
@using ClinicManagementSystem.Services.Interfaces
@using Microsoft.AspNetCore.Identity
@inject NavigationManager Navigation
@inject UserManager<AppUser> UserManager
@inject IAuditLogService AuditLogService

<PageTitle>Register</PageTitle>

<h1>Register</h1>

<div class="card mt-3" style="max-width: 640px;">
    <div class="card-body">
        <p class="text-muted">Self-registration creates a Receptionist account.</p>

        <EditForm EditContext="_editContext" OnValidSubmit="RegisterAsync">
            <DataAnnotationsValidator />

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label" for="register-first-name">First name</label>
                    <InputText id="register-first-name" @bind-Value="_model.FirstName" class="form-control" />
                    <ValidationMessage For="@(() => _model.FirstName)" class="text-danger" />
                </div>

                <div class="col-md-6">
                    <label class="form-label" for="register-last-name">Last name</label>
                    <InputText id="register-last-name" @bind-Value="_model.LastName" class="form-control" />
                    <ValidationMessage For="@(() => _model.LastName)" class="text-danger" />
                </div>

                <div class="col-12">
                    <label class="form-label" for="register-email">Email</label>
                    <InputText id="register-email" @bind-Value="_model.Email" class="form-control" type="email" />
                    <ValidationMessage For="@(() => _model.Email)" class="text-danger" />
                </div>

                <div class="col-md-6">
                    <label class="form-label" for="register-password">Password</label>
                    <InputText id="register-password" @bind-Value="_model.Password" class="form-control"
                               type="password" />
                    <ValidationMessage For="@(() => _model.Password)" class="text-danger" />
                </div>

                <div class="col-md-6">
                    <label class="form-label" for="register-confirm-password">Confirm password</label>
                    <InputText id="register-confirm-password" @bind-Value="_model.ConfirmPassword" class="form-control"
                               type="password" />
                    <ValidationMessage For="@(() => _model.ConfirmPassword)" class="text-danger" />
                </div>
            </div>

            <div class="d-flex gap-2 align-items-center mt-3">
                <button class="btn btn-primary" type="submit" disabled="@_isSubmitting">Create account</button>
                <a class="btn btn-outline-secondary" href="@LoginUrl">Back to login</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private readonly RegisterInputModel _model = new();
    private EditContext _editContext = default!;
    private ValidationMessageStore _messageStore = default!;
    private bool _isSubmitting;
    private string _returnUrl = "/";
    private string LoginUrl => $"/login?registered=1&returnUrl={Uri.EscapeDataString(_returnUrl)}";

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_model);
        _messageStore = new ValidationMessageStore(_editContext);
        _editContext.OnValidationRequested += (_, _) => _messageStore.Clear();
        _editContext.OnFieldChanged += (_, eventArgs) => _messageStore.Clear(eventArgs.FieldIdentifier);

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("returnUrl", out var returnUrl)
            || query.TryGetValue("ReturnUrl", out returnUrl))
        {
            _returnUrl = !string.IsNullOrWhiteSpace(returnUrl.ToString())
                ? returnUrl.ToString()
                : "/";
        }
    }

    private async Task RegisterAsync()
    {
        _isSubmitting = true;
        _messageStore.Clear();

        var trimmedEmail = _model.Email.Trim();

        if (await UserManager.FindByEmailAsync(trimmedEmail) is not null)
        {
            _messageStore.Add(new FieldIdentifier(_model, nameof(RegisterInputModel.Email)), "An account with that email already exists.");
            _editContext.NotifyValidationStateChanged();

            await AuditLogService.CreateAsync(new AuditLog
            {
                EntityName = "Authentication",
                ActionType = "RegistrationFailed",
                Description = $"Blazor registration failed for '{trimmedEmail}' because the email already exists"
            });

            _isSubmitting = false;
            return;
        }

        var user = new AppUser
        {
            UserName = trimmedEmail,
            Email = trimmedEmail,
            FirstName = _model.FirstName.Trim(),
            LastName = _model.LastName.Trim(),
            Role = UserRole.Receptionist,
            IsActive = true,
            EmailConfirmed = true,
            CreatedAt = DateTime.UtcNow,
            UpdatedAt = DateTime.UtcNow
        };

        var result = await UserManager.CreateAsync(user, _model.Password);
        if (!result.Succeeded)
        {
            foreach (var error in result.Errors)
            {
                AddIdentityError(error);
            }

            await AuditLogService.CreateAsync(new AuditLog
            {
                EntityName = "Authentication",
                ActionType = "RegistrationFailed",
                Description = $"Blazor registration failed for '{trimmedEmail}': {string.Join(" ", result.Errors.Select(error =>
error.Description))}"
            });

            _editContext.NotifyValidationStateChanged();
            _isSubmitting = false;
            return;
        }

        var roleResult = await UserManager.AddToRoleAsync(user, "Receptionist");
        if (!roleResult.Succeeded)
        {
            foreach (var error in roleResult.Errors)
            {
                AddIdentityError(error);
            }

            await UserManager.DeleteAsync(user);

            await AuditLogService.CreateAsync(new AuditLog
            {
                EntityName = "Authentication",
                ActionType = "RegistrationFailed",
                Description = $"Blazor role assignment failed for '{trimmedEmail}': {string.Join(" ", roleResult.Errors.Select(error =>
error.Description))}"
            });

            _editContext.NotifyValidationStateChanged();
            _isSubmitting = false;
            return;
        }

        await AuditLogService.CreateAsync(new AuditLog
        {
            EntityName = "Authentication",
            ActionType = "RegistrationSuccess",
            PerformedByUserId = user.Id,
            Description = $"Blazor self-registration succeeded for '{trimmedEmail}' with role 'Receptionist'"
        });

        Navigation.NavigateTo($"/login?registered=1&returnUrl={Uri.EscapeDataString(_returnUrl)}", forceLoad: true);
    }

    private void AddIdentityError(IdentityError error)
    {
        var fieldName = error.Code switch
        {
            "DuplicateEmail" => nameof(RegisterInputModel.Email),
            "DuplicateUserName" => nameof(RegisterInputModel.Email),
            var code when code.Contains("Email", StringComparison.OrdinalIgnoreCase) => nameof(RegisterInputModel.Email),
            var code when code.Contains("UserName", StringComparison.OrdinalIgnoreCase) => nameof(RegisterInputModel.Email),
            var code when code.Contains("Password", StringComparison.OrdinalIgnoreCase) => nameof(RegisterInputModel.Password),
            _ => nameof(RegisterInputModel.Email)
        };

        _messageStore.Add(new FieldIdentifier(_model, fieldName), error.Description);
    }

    private sealed class RegisterInputModel
    {
        [Required(ErrorMessage = "First name is required.")]
        [StringLength(100, ErrorMessage = "First name must be 100 characters or fewer.")]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Last name is required.")]
        [StringLength(100, ErrorMessage = "Last name must be 100 characters or fewer.")]
        public string LastName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        [DataType(DataType.Password)]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        [DataType(DataType.Password)]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
