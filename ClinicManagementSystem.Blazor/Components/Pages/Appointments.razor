@page "/appointments"
@attribute [Authorize(Roles = "Admin,Doctor,Receptionist")]
@rendermode InteractiveServer
@inject IAppointmentService AppointmentService
@inject IStaffService StaffService
@inject NavigationManager Nav
@inject ILogger<Appointments> Logger
@using ClinicManagementSystem.Models.Entities
@using ClinicManagementSystem.Models.Enums
@using ClinicManagementSystem.Services.Interfaces

<PageTitle>Appointments</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"
                 AlignItems="AlignItems.Center">
        <RadzenText TextStyle="TextStyle.H4">Appointments</RadzenText>
        <RadzenButton Text="New Appointment" Icon="add" ButtonStyle="ButtonStyle.Primary"
                      Click="@(() => Nav.NavigateTo("/appointments/new"))" />
    </RadzenStack>

    <!-- Filters -->
    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center">
        <RadzenFormField Text="Filter Date">
            <RadzenDatePicker @bind-Value="_filterDate" DateFormat="yyyy-MM-dd" Change="@OnDateChanged" />
        </RadzenFormField>
        <RadzenFormField Text="Status">
            <RadzenDropDown @bind-Value="_filterStatus" Data="@(Enum.GetValues<AppointmentStatus>())" AllowClear="true"
                            Change="@(_ => ApplyFilters())" Placeholder="Any status" />
        </RadzenFormField>
        <RadzenFormField Text="Staff">
            <RadzenDropDown @bind-Value="_filterStaffId" Data="@_staff" TextProperty="FullName" ValueProperty="Id"
                            AllowClear="true" Change="@(_ => LoadAsync())" Placeholder="Any staff" />
        </RadzenFormField>
        <RadzenButton Text="Clear" ButtonStyle="ButtonStyle.Light" Click="@ClearFilter" />
    </RadzenStack>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">
            Failed to load appointments. @_error
        </RadzenAlert>
        <RadzenButton Text="Retry" Icon="refresh" ButtonStyle="ButtonStyle.Light" Click="LoadAsync" />
    }

    <RadzenDataGrid Data="@_appointments" TItem="Appointment" AllowSorting="true" AllowPaging="true" PageSize="15"
                    IsLoading="@_loading">
        <Columns>
            <RadzenDataGridColumn TItem="Appointment" Property="AppointmentDate" Title="Date"
                                  FormatString="{0:yyyy-MM-dd}" />
            <RadzenDataGridColumn TItem="Appointment" Property="StartTime" Title="Start" />
            <RadzenDataGridColumn TItem="Appointment" Property="EndTime" Title="End" />
            <RadzenDataGridColumn TItem="Appointment" Property="Patient.FullName" Title="Patient" />
            <RadzenDataGridColumn TItem="Appointment" Property="StaffMember.FullName" Title="Doctor" />
            <RadzenDataGridColumn TItem="Appointment" Property="AppointmentType" Title="Type" />
            <RadzenDataGridColumn TItem="Appointment" Property="Status" Title="Status">
                <Template Context="appt">
                    <RadzenBadge BadgeStyle="@GetBadgeStyle(appt.Status)" Text="@appt.Status.ToString()" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Appointment" Property="IsPredictedNoShow" Title="No-Show Risk" Width="130px">
                <Template Context="appt">
                    @if (appt.IsPredictedNoShow)
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="High Risk" />
                    }
                    else
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="Low Risk" />
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Appointment" Title="Actions" Width="140px" Sortable="false">
                <Template Context="appt">
                    <RadzenButton Icon="visibility" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  Click="@(() => Nav.NavigateTo($"/appointments/{appt.Id}"))" />
                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small"
                                  Click="@(() => Nav.NavigateTo($"/appointments/{appt.Id}/edit"))" />
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                  Click="@(() => DeleteAppointment(appt.Id))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
        <EmptyTemplate>
            <RadzenText TextStyle="TextStyle.Body2">No appointments found for the selected filters.</RadzenText>
        </EmptyTemplate>
    </RadzenDataGrid>
</RadzenStack>

<RadzenNotification />

@code {
    private List<Appointment> _allAppointments = [];
    private IEnumerable<Appointment> _appointments = [];
    private IEnumerable<StaffMember> _staff = [];
    private bool _loading = true;
    private DateTime? _filterDate;
    private AppointmentStatus? _filterStatus;
    private Guid? _filterStaffId;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Loading appointments page");
        _staff = await StaffService.GetAllAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _allAppointments = _filterStaffId.HasValue
                ? (await AppointmentService.GetByStaffAsync(_filterStaffId.Value)).ToList()
                : (await AppointmentService.GetAllAsync()).ToList();

            ApplyFilters();
            Logger.LogInformation("Loaded {Count} appointments", _appointments.Count());
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _appointments = [];
            _allAppointments = [];
            Logger.LogError(ex, "Failed to load appointments");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnDateChanged(DateTime? date)
    {
        _filterDate = date;
        ApplyFilters();
        await Task.CompletedTask;
    }

    private async Task ClearFilter()
    {
        _filterDate = null;
        _filterStatus = null;
        _filterStaffId = null;
        await LoadAsync();
    }

    private async Task DeleteAppointment(Guid id)
    {
        Logger.LogInformation("Deleting appointment {AppointmentId}", id);
        await AppointmentService.DeleteAsync(id);
        await LoadAsync();
    }

    private void ApplyFilters()
    {
        IEnumerable<Appointment> query = _allAppointments;

        if (_filterDate.HasValue)
        {
            var date = _filterDate.Value.Date;
            query = query.Where(a => a.AppointmentDate.Date == date);
        }

        if (_filterStatus.HasValue)
        {
            var status = _filterStatus.Value;
            query = query.Where(a => a.Status == status);
        }

        _appointments = query
            .OrderBy(a => a.AppointmentDate)
            .ThenBy(a => a.StartTime)
            .ToList();
    }

    private static BadgeStyle GetBadgeStyle(AppointmentStatus status) => status switch
    {
        AppointmentStatus.Completed => BadgeStyle.Success,
        AppointmentStatus.Cancelled => BadgeStyle.Warning,
        AppointmentStatus.NoShow => BadgeStyle.Danger,
        AppointmentStatus.Scheduled => BadgeStyle.Info,
        _ => BadgeStyle.Secondary
    };
}