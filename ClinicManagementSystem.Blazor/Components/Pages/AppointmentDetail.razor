@page "/appointments/{Id:guid}"
@attribute [Authorize(Roles = "Admin,Doctor,Receptionist")]
@rendermode InteractiveServer
@inject IAppointmentService AppointmentService
@inject IPredictionService PredictionService
@inject NavigationManager Nav
@inject ILogger<AppointmentDetail> Logger
@using ClinicManagementSystem.Models.Entities
@using ClinicManagementSystem.Models.DTOs
@using ClinicManagementSystem.Models.Enums
@using ClinicManagementSystem.Services.Interfaces

<PageTitle>Appointment Details</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"
                 AlignItems="AlignItems.Center">
        <RadzenText TextStyle="TextStyle.H4">Appointment Details</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="Recalculate Risk" Icon="psychology" ButtonStyle="ButtonStyle.Warning"
                          Click="RunPrediction" />
            <RadzenButton Text="Edit" Icon="edit" ButtonStyle="ButtonStyle.Secondary"
                          Click="@(() => Nav.NavigateTo($"/appointments/{Id}/edit"))" />
            <RadzenButton Text="Back" Icon="arrow_back" ButtonStyle="ButtonStyle.Light"
                          Click="@(() => Nav.NavigateTo("/appointments"))" />
        </RadzenStack>
    </RadzenStack>

    @if (_loading)
    {
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">
            Failed to load appointment details. @_error
        </RadzenAlert>
    }
    else if (_appointment is null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
            Appointment not found.
        </RadzenAlert>
    }
    else
    {
        <RadzenCard Style=@($"border-left: 5px solid {GetRiskColor(CurrentRiskLabel)};")>
            <RadzenStack Gap=" 0.25rem">
                <RadzenText TextStyle="TextStyle.H6">No-Show Risk</RadzenText>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                    <RadzenBadge BadgeStyle="@GetRiskBadgeStyle(CurrentRiskLabel)" Text="@($"{CurrentRiskLabel} Risk")" />
                    <RadzenText TextStyle="TextStyle.Body1">Probability: @CurrentRiskProbabilityDisplay</RadzenText>
                </RadzenStack>
                <RadzenText TextStyle="TextStyle.Body2"><strong>Recommendation:</strong> @CurrentRecommendation</RadzenText>
            </RadzenStack>
        </RadzenCard>

        <RadzenCard>
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeXS="12" SizeMD="6">
                    <RadzenText TextStyle="TextStyle.Overline">Patient</RadzenText>
                    <RadzenText>@(_appointment.Patient?.FullName ?? "N/A")</RadzenText>
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeMD="6">
                    <RadzenText TextStyle="TextStyle.Overline">Staff</RadzenText>
                    <RadzenText>@(_appointment.StaffMember?.FullName ?? "N/A")</RadzenText>
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeMD="4">
                    <RadzenText TextStyle="TextStyle.Overline">Date</RadzenText>
                    <RadzenText>@_appointment.AppointmentDate.ToString("yyyy-MM-dd")</RadzenText>
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeMD="4">
                    <RadzenText TextStyle="TextStyle.Overline">Start</RadzenText>
                    <RadzenText>@_appointment.StartTime</RadzenText>
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeMD="4">
                    <RadzenText TextStyle="TextStyle.Overline">End</RadzenText>
                    <RadzenText>@_appointment.EndTime</RadzenText>
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeMD="4">
                    <RadzenText TextStyle="TextStyle.Overline">Type</RadzenText>
                    <RadzenText>@_appointment.AppointmentType</RadzenText>
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeMD="4">
                    <RadzenText TextStyle="TextStyle.Overline">Status</RadzenText>
                    <RadzenBadge BadgeStyle="@GetStatusBadgeStyle(_appointment.Status)"
                                 Text="@_appointment.Status.ToString()" />
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeMD="4">
                    <RadzenText TextStyle="TextStyle.Overline">Reminder Sent</RadzenText>
                    <RadzenText>@(_appointment.ReminderSent ? "Yes" : "No")</RadzenText>
                </RadzenColumn>
                <RadzenColumn SizeXS="12">
                    <RadzenText TextStyle="TextStyle.Overline">Reason</RadzenText>
                    <RadzenText>@(_appointment.Reason ?? "N/A")</RadzenText>
                </RadzenColumn>
                <RadzenColumn SizeXS="12">
                    <RadzenText TextStyle="TextStyle.Overline">Notes</RadzenText>
                    <RadzenText>@(_appointment.Notes ?? "No notes")</RadzenText>
                </RadzenColumn>
            </RadzenRow>
        </RadzenCard>
    }
</RadzenStack>

@code {
    [Parameter] public Guid Id { get; set; }

    private Appointment? _appointment;
    private NoShowPredictionOutput? _prediction;
    private bool _loading = true;
    private string? _error;

    private string CurrentRiskLabel
        => _prediction?.RiskLevel
            ?? GetRiskLabelFromProbability(_appointment?.NoShowProbability, _appointment?.IsPredictedNoShow ?? false);

    private string CurrentRiskProbabilityDisplay
        => _prediction is not null
            ? $"{Math.Round(_prediction.Probability * 100, 1)}%"
            : _appointment?.NoShowProbability is decimal probability
                ? $"{Math.Round(probability * 100, 1)}%"
                : "Not scored";

    private string CurrentRecommendation
        => _prediction?.Recommendation ?? GetRecommendation(CurrentRiskLabel);

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Loading appointment detail {AppointmentId}", Id);
        await LoadAppointmentAsync();
    }

    private async Task LoadAppointmentAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _appointment = await AppointmentService.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to load appointment detail {AppointmentId}", Id);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RunPrediction()
    {
        _error = null;
        try
        {
            _prediction = await PredictionService.PredictNoShowForAppointmentAsync(Id, persistResult: true);
            await LoadAppointmentAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogError(ex, "Failed to run no-show prediction for appointment {AppointmentId}", Id);
        }
    }

    private static BadgeStyle GetStatusBadgeStyle(AppointmentStatus status) => status switch
    {
        AppointmentStatus.Completed => BadgeStyle.Success,
        AppointmentStatus.Cancelled => BadgeStyle.Warning,
        AppointmentStatus.NoShow => BadgeStyle.Danger,
        AppointmentStatus.Scheduled => BadgeStyle.Info,
        AppointmentStatus.Confirmed => BadgeStyle.Primary,
        _ => BadgeStyle.Secondary
    };

    private static string GetRiskLabelFromProbability(decimal? probability, bool isPredictedNoShow)
    {
        if (!probability.HasValue)
        {
            return isPredictedNoShow ? "High" : "Not Scored";
        }

        return probability < 0.40m ? "Low" : probability <= 0.70m ? "Medium" : "High";
    }

    private static BadgeStyle GetRiskBadgeStyle(string riskLabel) => riskLabel switch
    {
        "High" => BadgeStyle.Danger,
        "Medium" => BadgeStyle.Warning,
        "Low" => BadgeStyle.Success,
        _ => BadgeStyle.Secondary
    };

    private static string GetRiskColor(string riskLabel) => riskLabel switch
    {
        "High" => "#d32f2f",
        "Medium" => "#ed6c02",
        "Low" => "#2e7d32",
        _ => "#607d8b"
    };

    private static string GetRecommendation(string riskLabel) => riskLabel switch
    {
        "High" => "Confirm attendance by phone, send same-day reminder, and prepare backup slot.",
        "Medium" => "Send additional reminder and request confirmation 24 hours before visit.",
        "Low" => "Continue standard reminder workflow.",
        _ => "Run risk calculation to generate recommendation."
    };
}
