@page "/appointments/new"
@page "/appointments/{Id:guid}/edit"
@attribute [Authorize(Roles = "Admin,Doctor,Receptionist")]
@rendermode InteractiveServer
@inject IAppointmentService AppointmentService
@inject IPatientService PatientService
@inject IStaffService StaffService
@inject IPredictionService PredictionService
@inject NavigationManager Nav
@inject NotificationService Notify
@inject ILogger<AppointmentForm> Logger
@using ClinicManagementSystem.Models.Entities
@using ClinicManagementSystem.Models.Enums
@using ClinicManagementSystem.Models.DTOs
@using ClinicManagementSystem.Services.Interfaces

<PageTitle>@(_isNew ? "New Appointment" : "Edit Appointment")</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
        <RadzenText TextStyle="TextStyle.H4">@(_isNew ? "New Appointment" : "Edit Appointment")</RadzenText>
        <RadzenButton Text="Back" Icon="arrow_back" ButtonStyle="ButtonStyle.Light"
                      Click="@(() => Nav.NavigateTo("/appointments"))" />
    </RadzenStack>

    @if (!string.IsNullOrWhiteSpace(_validationMessage))
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">@_validationMessage</RadzenAlert>
    }

    @if (!string.IsNullOrWhiteSpace(_conflictWarning))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">
            <strong>Scheduling Conflict</strong><br />
            @_conflictWarning<br />
            Try changing staff member, date, or time range.
        </RadzenAlert>
    }

    @if (_prediction is not null)
    {
        <RadzenCard Style=@($"border-left: 5px solid {GetRiskColor(_prediction.RiskLevel)};")>
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.H6">No-Show Risk Assessment</RadzenText>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                    <RadzenBadge Text="@($"{_prediction.RiskLevel} Risk")" BadgeStyle="@GetRiskBadgeStyle(_prediction.RiskLevel)" />
                    <RadzenText TextStyle="TextStyle.Body1">Probability: @Math.Round(_prediction.Probability * 100, 1)%</RadzenText>
                </RadzenStack>
                <RadzenText TextStyle="TextStyle.Body2"><strong>Recommendation:</strong> @_prediction.Recommendation</RadzenText>
            </RadzenStack>
        </RadzenCard>
    }

    <RadzenCard>
        <RadzenTemplateForm TItem="Appointment" Data="@_appointment" Submit="@OnSubmit">
            <RadzenRow Gap="1rem">
                <RadzenColumn SizeXS="12" SizeSM="6">
                    <RadzenFormField Text="Patient" Style="width:100%">
                        <RadzenDropDown @bind-Value="_appointment.PatientId"
                                        Data="@_patients" TextProperty="FullName" ValueProperty="Id"
                                        Name="PatientId" Placeholder="Select patient" Style="width:100%" />
                        <RadzenRequiredValidator Component="PatientId" Text="Patient is required" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeSM="6">
                    <RadzenFormField Text="Doctor / Staff" Style="width:100%">
                        <RadzenDropDown @bind-Value="_appointment.StaffMemberId"
                                        Data="@_staff" TextProperty="FullName" ValueProperty="Id"
                                        Name="StaffMemberId" Placeholder="Select staff" Style="width:100%" />
                        <RadzenRequiredValidator Component="StaffMemberId" Text="Staff member is required" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeSM="6">
                    <RadzenFormField Text="Appointment Type" Style="width:100%">
                        <RadzenDropDown @bind-Value="_appointment.AppointmentType"
                                        Data="@(Enum.GetValues<AppointmentType>())" Name="AppointmentType" Style="width:100%" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeSM="6">
                    <RadzenFormField Text="Status" Style="width:100%">
                        <RadzenDropDown @bind-Value="_appointment.Status"
                                        Data="@(Enum.GetValues<AppointmentStatus>())" Name="Status" Style="width:100%" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeSM="4">
                    <RadzenFormField Text="Date" Style="width:100%">
                        <RadzenDatePicker @bind-Value="_appointment.AppointmentDate" Name="AppointmentDate" DateFormat="yyyy-MM-dd"
                                          Style="width:100%" />
                        <RadzenRequiredValidator Component="AppointmentDate" Text="Appointment date is required" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeSM="4">
                    <RadzenFormField Text="Start Time" Style="width:100%">
                        <RadzenDatePicker @bind-Value="_startTimeBind" ShowTime="true" ShowSeconds="false"
                                          TimeOnly="true" DateFormat="HH:mm" Style="width:100%" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeXS="12" SizeSM="4">
                    <RadzenFormField Text="End Time" Style="width:100%">
                        <RadzenDatePicker @bind-Value="_endTimeBind" ShowTime="true" ShowSeconds="false"
                                          TimeOnly="true" DateFormat="HH:mm" Style="width:100%" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeXS="12">
                    <RadzenFormField Text="Reason" Style="width:100%">
                        <RadzenTextBox @bind-Value="_appointment.Reason" Name="Reason" MaxLength="500" Style="width:100%" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn SizeXS="12">
                    <RadzenFormField Text="Notes" Style="width:100%">
                        <RadzenTextArea @bind-Value="_appointment.Notes" Name="Notes" Rows="3" MaxLength="2000" Style="width:100%" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn SizeXS="12">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                        <RadzenButton ButtonType="ButtonType.Submit" Text="Save Appointment" Icon="save" ButtonStyle="ButtonStyle.Primary" />
                        <RadzenButton Text="Run Risk Check" Icon="psychology" ButtonStyle="ButtonStyle.Warning"
                                      ButtonType="ButtonType.Button" Click="@RunPrediction" />
                        <RadzenButton Text="Cancel" Icon="cancel" ButtonStyle="ButtonStyle.Light"
                                      Click="@(() => Nav.NavigateTo("/appointments"))" />
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </RadzenTemplateForm>
    </RadzenCard>
</RadzenStack>

<RadzenNotification />

@code {
    [Parameter] public Guid? Id { get; set; }

    private Appointment _appointment = new() { AppointmentDate = DateTime.Today, Status = AppointmentStatus.Scheduled };
    private IEnumerable<Patient> _patients = [];
    private IEnumerable<StaffMember> _staff = [];
    private bool _isNew = true;
    private NoShowPredictionOutput? _prediction;
    private string? _conflictWarning;
    private string? _validationMessage;

    private DateTime _startTimeBind = DateTime.Today.AddHours(9);
    private DateTime _endTimeBind = DateTime.Today.AddHours(9).AddMinutes(30);

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Loading appointment form");
        _patients = await PatientService.GetAllAsync();
        _staff = await StaffService.GetAllAsync();

        if (Id.HasValue)
        {
            var existing = await AppointmentService.GetByIdAsync(Id.Value);
            if (existing is not null)
            {
                _appointment = existing;
                _isNew = false;
                _startTimeBind = DateTime.Today.Add(_appointment.StartTime);
                _endTimeBind = DateTime.Today.Add(_appointment.EndTime);
            }
        }
    }

    private async Task OnSubmit(Appointment appointment)
    {
        _conflictWarning = null;
        _validationMessage = ValidateForm();
        if (!string.IsNullOrWhiteSpace(_validationMessage))
        {
            Notify.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Warning,
                Summary = "Please review the form",
                Detail = _validationMessage,
                Duration = 5000
            });
            return;
        }

        appointment.StartTime = _startTimeBind.TimeOfDay;
        appointment.EndTime = _endTimeBind.TimeOfDay;

        try
        {
            if (_isNew)
            {
                Logger.LogInformation("Creating appointment");
                await AppointmentService.CreateAsync(appointment);
                Notify.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Appointment created" });
            }
            else
            {
                Logger.LogInformation("Updating appointment {Id}", appointment.Id);
                await AppointmentService.UpdateAsync(appointment);
                Notify.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Appointment updated" });
            }

            Nav.NavigateTo("/appointments");
        }
        catch (ArgumentException ex)
        {
            _validationMessage = ex.Message;
            Notify.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Warning,
                Summary = "Validation error",
                Detail = ex.Message,
                Duration = 5000
            });
        }
        catch (InvalidOperationException ex)
        {
            _conflictWarning = ex.Message;
            Notify.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Scheduling conflict",
                Detail = ex.Message,
                Duration = 6000
            });
        }
    }

    private async Task RunPrediction()
    {
        _validationMessage = ValidateForm(skipTimeValidation: false);
        if (!string.IsNullOrWhiteSpace(_validationMessage))
        {
            return;
        }

        var patient = _patients.FirstOrDefault(p => p.Id == _appointment.PatientId);
        if (patient is null)
        {
            _validationMessage = "Select a patient before running risk check.";
            return;
        }

        Logger.LogInformation("Running no-show prediction for patient {PatientId}", patient.Id);
        var input = new NoShowPredictionInput
        {
            PatientAge = patient.Age,
            DaysBetweenBookingAndAppointment = Math.Max(0, (int)(_appointment.AppointmentDate.Date - DateTime.Today).TotalDays),
            AppointmentType = _appointment.AppointmentType,
            DayOfWeek = _appointment.AppointmentDate.DayOfWeek,
            HasInsurance = patient.HasInsurance,
            HasReminderSent = _appointment.ReminderSent,
            PreviousCompletedCount = 0,
            PreviousNoShowCount = 0
        };

        _prediction = await PredictionService.PredictNoShowAsync(input);
        _appointment.IsPredictedNoShow = _prediction.WillNoShow;
        _appointment.NoShowProbability = _prediction.Probability;
    }

    private string? ValidateForm(bool skipTimeValidation = false)
    {
        if (_appointment.PatientId == Guid.Empty)
        {
            return "Patient is required.";
        }

        if (_appointment.StaffMemberId == Guid.Empty)
        {
            return "Staff member is required.";
        }

        if (_appointment.AppointmentDate == default)
        {
            return "Appointment date is required.";
        }

        if (!skipTimeValidation && _startTimeBind.TimeOfDay >= _endTimeBind.TimeOfDay)
        {
            return "Start Time must be earlier than End Time.";
        }

        return null;
    }

    private static BadgeStyle GetRiskBadgeStyle(string riskLevel) => riskLevel switch
    {
        "High" => BadgeStyle.Danger,
        "Medium" => BadgeStyle.Warning,
        _ => BadgeStyle.Success
    };

    private static string GetRiskColor(string riskLevel) => riskLevel switch
    {
        "High" => "#d32f2f",
        "Medium" => "#ed6c02",
        _ => "#2e7d32"
    };
}
