@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Antiforgery
@inject IHttpContextAccessor HttpContextAccessor
@inject IAntiforgery AntiforgeryService

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="me-3">@context.User.Identity?.Name</span>
                    <form method="post" action="/account/logout" style="display:inline;">
                        @if (HttpContextAccessor?.HttpContext != null)
                        {
                            var tokens = AntiforgeryService.GetAndStoreTokens(HttpContextAccessor.HttpContext);
                            <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
                        }
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Logout</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-primary" href="/login">Login</a>
                        <a class="btn btn-sm btn-primary" href="/register">Register</a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
<RadzenComponents @rendermode="InteractiveServer" />