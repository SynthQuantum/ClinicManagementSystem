{
  "ConnectionStrings": {
    "ClinicDb": "Server=tcp:clinicmanagmentprod-server.database.windows.net,1433;Initial Catalog=clinicmanagmentprod-db;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;Authentication=\"Active Directory Default\";"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Error"
    }
  },
  "Jwt": {
    "Key": "",
    "Issuer": "ClinicManagementSystem.API",
    "Audience": "ClinicManagementSystem.API",
    "ExpiryMinutes": 480
  },
  "NotificationReminders": {
    "Enabled": true,
    "EnableSecondReminder": true,
    "FirstReminderHoursBefore": 24,
    "SecondReminderHoursBefore": 2,
    "AppointmentLookAheadDays": 30,
    "ProcessingBatchSize": 200,
    "ProcessorIntervalSeconds": 120
  },
  "PerformanceMonitoring": {
    "Enabled": true,
    "PersistToDatabase": true,
    "FlushIntervalSeconds": 30,
    "MaxInMemorySamples": 4000,
    "MaxSummarySamples": 10000,
    "SummaryLookbackHours": 24,
    "SlowEndpointCount": 5,
    "RecentFailedRequestCount": 10
  }
}
