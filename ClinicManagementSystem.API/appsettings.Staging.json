{
  "ConnectionStrings": {
    "ClinicDb": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Authentication": {
    "Jwt": {
      "Key": "",
      "Issuer": "ClinicManagementSystem.API",
      "Audience": "ClinicManagementSystem.API",
      "ExpiryMinutes": 480
    },
    "IdentitySeed": {
      "SeedAdmin": false,
      "AdminEmail": "",
      "AdminPassword": ""
    }
  },
  "NotificationReminders": {
    "Enabled": true,
    "EnableSecondReminder": true,
    "FirstReminderHoursBefore": 24,
    "SecondReminderHoursBefore": 2,
    "AppointmentLookAheadDays": 30,
    "ProcessingBatchSize": 150,
    "ProcessorIntervalSeconds": 90
  },
  "PerformanceMonitoring": {
    "Enabled": true,
    "PersistToDatabase": true,
    "FlushIntervalSeconds": 20,
    "MaxInMemorySamples": 3000,
    "MaxSummarySamples": 5000,
    "SummaryLookbackHours": 24,
    "SlowEndpointCount": 5,
    "RecentFailedRequestCount": 10
  },
  "MlArtifacts": {
    "NoShowArtifactsPath": "ml-artifacts/no-show",
    "ModelFileName": "no_show_model.zip",
    "DatasetFileName": "no_show_training_data.csv",
    "MetricsFileName": "no_show_model_metrics.json"
  },
  "StartupBehavior": {
    "ApplyMigrations": true,
    "EnsureCreatedWhenNoMigrations": true,
    "SeedDevelopmentData": false,
    "SeedIdentityData": false,
    "FailFastOnInitializationError": true
  }
}
