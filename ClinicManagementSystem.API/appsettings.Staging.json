{
  "ConnectionStrings": {
    "ClinicDb": "Server=tcp:clinicmanagement-staging.database.windows.net,1433;Initial Catalog=ClinicManagement-Staging;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;Authentication=Active Directory Default;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Jwt": {
    "Key": "",
    "Issuer": "ClinicManagementSystem.API",
    "Audience": "ClinicManagementSystem.API",
    "ExpiryMinutes": 480
  },
  "NotificationReminders": {
    "Enabled": true,
    "EnableSecondReminder": true,
    "FirstReminderHoursBefore": 24,
    "SecondReminderHoursBefore": 2,
    "AppointmentLookAheadDays": 30,
    "ProcessingBatchSize": 150,
    "ProcessorIntervalSeconds": 90
  },
  "PerformanceMonitoring": {
    "Enabled": true,
    "PersistToDatabase": true,
    "FlushIntervalSeconds": 20,
    "MaxInMemorySamples": 3000,
    "MaxSummarySamples": 5000,
    "SummaryLookbackHours": 24,
    "SlowEndpointCount": 5,
    "RecentFailedRequestCount": 10
  }
}
